# ============================================================
# App Review Insights — Environment Variables
# ============================================================
# 1. Copy this file to .env (backend/.env for backend-only usage)
# 2. Fill in the required values below
# ============================================================

# --- LLM / OpenAI-compatible API ---
# Required. Your API key for the LLM provider (OpenAI, DeepSeek, etc.)
OPENAI_API_KEY=

# Optional. Model name (default: gpt-4o-mini)
# Examples: gpt-4o, deepseek-chat, deepseek-v4-flash
OPENAI_MODEL=gpt-4o-mini

# Optional. Base URL for OpenAI-compatible API (default: https://api.openai.com/v1)
# For DeepSeek: https://api.deepseek.com/v1
OPENAI_BASE_URL=

# --- Frontend ---
# Optional. The URL where the frontend is served (default: http://localhost:3000)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# --- Backend ---
# Optional. Allowed CORS origins, comma-separated (default: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000